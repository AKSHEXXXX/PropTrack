# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=proptrack
DB_PASSWORD=proptrack_secret
DB_DATABASE=proptrack_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
